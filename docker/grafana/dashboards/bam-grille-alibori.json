          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  COALESCE(commune, 'Non attribuee') AS commune,\n  COUNT(*)::int AS nb_points,\n  COUNT(*) FILTER (WHERE est_humide = true)::int AS zones_humides,\n  ROUND(AVG(score_total)::numeric, 1)::float8 AS score_moyen,\n  ROUND(AVG(ndwi)::numeric, 4)::float8 AS ndwi_moyen\nFROM grille_nationale\nWHERE departement = '$departement'\nGROUP BY commune\nORDER BY zones_humides DESC, score_moyen DESC NULLS LAST",
          "refId": "A"
        }
      ]
