          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  lat::float8 AS latitude,\n  lon::float8 AS longitude,\n  commune,\n  ndwi::float8 AS ndwi,\n  twi::float8 AS twi,\n  score_total::float8 AS score_total,\n  priorite,\n  est_humide,\n  source_ndwi\nFROM grille_nationale\nWHERE departement = '$departement'\n  AND lat IS NOT NULL\n  AND lon IS NOT NULL\n  AND score_total IS NOT NULL\nORDER BY score_total DESC NULLS LAST",
